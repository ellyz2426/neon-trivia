<panel width="300" height="160" background-color="#0a0a2a" border-radius="12" padding="16" gap="10" flex-direction="column" align-items="center">
  <text font-size="24" color="#00ffff" font-weight="bold">PAUSED</text>
  <text name="btn-resume" font-size="20" color="#66ff66" background-color="#003300" padding="8" border-radius="6" width="200" text-align="center" hover-color="#005500">RESUME</text>
  <text name="btn-quit" font-size="20" color="#ff4444" background-color="#330000" padding="8" border-radius="6" width="200" text-align="center" hover-color="#550000">QUIT</text>
</panel>
